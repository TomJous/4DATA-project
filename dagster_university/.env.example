# Token d'accès à l'API TheMovieDB (https://developer.themoviedb.org)
API_TOKEN=

# Paramètres PostgreSQL — utilisés par Docker Compose pour créer la base
# Choisissez librement un nom de base, un utilisateur et un mot de passe
POSTGRES_DB=movies_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=votre_mot_de_passe

# Chaîne de connexion complète
# - Depuis un container Docker : host = nom du service = "postgres"
# - Depuis la machine hôte (tests locaux) : host = "localhost"
POSTGRES_CONNECTION_STRING=postgresql://postgres:votre_mot_de_passe@postgres:5432/movies_db